<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="380.0" prefWidth="438.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FinanzasController">
    <stylesheets>
        <URL value="@/css/aiops_style.css" />
    </stylesheets>
    <children>
        <Label layoutX="14.0" layoutY="10.0" text="Ingresos por Tipo y País" textFill="#1a1c27">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="14.0" layoutY="40.0" text="Desde:" />
        <DatePicker fx:id="fechaInicio" layoutX="58.0" layoutY="35.0" prefWidth="110.0" />

        <Label layoutX="185.0" layoutY="40.0" text="Hasta:" />
        <DatePicker fx:id="fechaFin" layoutX="225.0" layoutY="35.0" prefWidth="110.0" />

        <PieChart fx:id="graficoIngresos" legendVisible="false" labelsVisible="true" layoutX="10.0" layoutY="55.0" prefHeight="205.0" prefWidth="418.0" />

        <GridPane fx:id="leyendaCustom" layoutX="30.0" layoutY="260.0" prefWidth="398.0" hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0" />
                <ColumnConstraints percentWidth="50.0" />
            </columnConstraints>
        </GridPane>
    </children>
</AnchorPane>