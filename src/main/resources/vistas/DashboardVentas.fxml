<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="380.0" prefWidth="438.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.VentasController">

    <stylesheets>
        <URL value="@/css/aiops_style.css" />
    </stylesheets>

    <children>
        <Label layoutX="14.0" layoutY="14.0" text="Tendencia de Facturación" textFill="#1a1c27">
            <font>
                <Font name="Montserrat Bold" size="18.0" />
            </font>
        </Label>

        <LineChart fx:id="graficoVentas" animated="false" layoutX="4.0" layoutY="50.0" prefHeight="320.0" prefWidth="430.0" title="Ingresos Mensuales" legendVisible="false">
            <xAxis>
                <CategoryAxis label="Mes / Año" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Monto Total ($)" side="LEFT" />
            </yAxis>
        </LineChart>
    </children>
</AnchorPane>